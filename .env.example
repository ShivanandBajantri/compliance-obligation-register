# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/compliance_db
SPRING_DATASOURCE_USERNAME=compliance_user
SPRING_DATASOURCE_PASSWORD=compliance_password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# ── Redis ─────────────────────────────────────────────────────────────────────
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ── Spring profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080

# ── Email ─────────────────────────────────────────────────────────────────────
# For Gmail: enable 2FA and generate an App Password at
# https://myaccount.google.com/apppasswords
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-secret-before-production-deploy

# ── Logging ───────────────────────────────────────────────────────────────────
LOGGING_LEVEL_COM_INTERNSHIP_TOOL=INFO
