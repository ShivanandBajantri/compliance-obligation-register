# ═══════════════════════════════════════════════════════════════════════════════
# .gitignore — Compliance Obligation Register
# Protects credentials, secrets, build artefacts, and IDE files from being
# committed to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── SECRETS & CREDENTIALS (most important) ────────────────────────────────────

# Environment variable files — NEVER commit these (contain DB passwords, JWT
# secrets, SMTP credentials, API keys)
.env
.env.*
!.env.example

# Spring Boot property files — contain DB URLs, passwords, mail credentials.
# Only the .template file (no real values) is safe to commit.
application.properties
application-*.properties
!application.properties.template
application.yml
application-*.yml
!application.yml.template

# Spring Boot data seed files — may contain hashed passwords or PII
data.sql
import.sql

# Security key material
*.key
*.pem
*.crt
*.cer
*.p12
*.jks
*.keystore
*.truststore
secrets/
config/secrets/
**/secrets/

# ── JAVA / MAVEN ──────────────────────────────────────────────────────────────
*.class
target/
*.jar
*.war
*.nar
*.ear
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar
hs_err_pid*
replay_pid*

# ── NODE.JS / FRONTEND ────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
frontend/build/

# ── PYTHON / AI SERVICE ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
dist/
*.egg-info/

# ── BUILD ARTEFACTS ───────────────────────────────────────────────────────────
build/
.gradle/
*.zip
*.tar.gz
*.rar

# ── LOGS ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── DATABASE FILES ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── TEMPORARY / BACKUP ────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo

# ── IDE & EDITOR ──────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
.vscode/
*.code-workspace
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ── OS FILES ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── MISC PROJECT FILES ────────────────────────────────────────────────────────
# Stray files that should not be in the repo
commit_msg.txt
*.ctxt
.mtj.tmp/
